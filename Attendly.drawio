<mxfile host="app.diagrams.net" agent="Mozilla/5.0 (X11; Linux x86_64; rv:148.0) Gecko/20100101 Firefox/148.0" version="29.6.1">
  <diagram name="Page-1" id="0fsDh7_RbNI2BF3FRoxZ">
    <mxGraphModel dx="1128" dy="810" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\ntitle Attendly - Activity Diagram (End-to-End Flow)\n\nstart\n\n:Initialize DB (optional);\nif (attendance_system.db exists?) then (yes)\n  :Connect to existing DB;\nelse (no)\n  :Create attendance_system.db;\nendif\n:Ensure tables exist:\\n- Users\\n- Attendance;\n\npartition \&quot;User Registration (register_user.py)\&quot; {\n  :Input name + role;\n  :Insert into Users table;\n  :Get user_id (lastrowid);\n  :Create folder dataset/{user_id}_{name};\n  :Open webcam;\n  :Loop until num_images captured or user quits;\n  while (captured &lt; num_images AND not quit?) is (yes)\n    :Show live frame + face box;\n    if (key == &#39;c&#39;?) then (capture)\n      :Save face_{n}.jpg;\n      :captured++;\n    elseif (key == &#39;q&#39;?) then (quit)\n      break\n    endif\n  endwhile (no)\n  :Close webcam;\n}\n\npartition \&quot;Encode Faces (encode_faces.py)\&quot; {\n  if (dataset/ exists?) then (yes)\n    :For each user folder in dataset/;\n    :For each image in folder;\n    :Load image (cv2);\n    :Convert BGR -&gt; RGB;\n    :Detect face locations;\n    :Compute face encodings;\n    :Append encoding + name + id to lists;\n    :Serialize to encodings.pickle;\n  else (no)\n    :Show error:\\nRun register_user.py first;\n    stop\n  endif\n}\n\npartition \&quot;Run Attendance System (main_attendance.py)\&quot; {\n  if (encodings.pickle exists?) then (yes)\n    :Load encodings.pickle;\n  else (no)\n    :Show error:\\nRun encode_faces.py first;\n    stop\n  endif\n\n  :Start webcam stream;\n  :Initialize local_attendance_cache;\n\n  while (camera running?) is (yes)\n    :Read frame;\n    :Resize frame (1/4);\n    :Convert BGR -&gt; RGB;\n    :Detect face locations + encodings;\n\n    :For each face encoding;\n    :Compare against known encodings;\n    if (best match found?) then (yes)\n      :Get name + user_id;\n      if (Already marked today\\n(local cache)?) then (yes)\n        :Skip logging;\n      else (no)\n        :Query DB:\\nAttendance where user_id + date;\n        if (Record exists?) then (yes)\n          :Update local cache;\n        else (no)\n          :Insert Attendance(user_id,date,time);\n          :Update local cache;\n        endif\n      endif\n    else (no)\n      :Label as Unknown;\n    endif\n\n    :Render boxes + names;\n    if (key == &#39;e&#39;?) then (export)\n      :Join Users + Attendance;\n      if (records exist?) then (yes)\n        :Write Attendance_Report_{timestamp}.csv;\n      else (no)\n        :Print no records;\n      endif\n    elseif (key == &#39;q&#39;?) then (quit)\n      break\n    endif\n  endwhile (no)\n\n  :Release webcam;\n}\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="GrXhS4B0xG5MaqtuPPGj-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="3041" width="750" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
